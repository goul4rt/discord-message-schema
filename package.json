{
  "name": "@delfus/discord-message-schema",
  "version": "0.1.0",
  "description": "Shared Zod schemas, Discord limits and wire types for Delfus rich messages (front-end ↔ discord-bot contract)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goul4rt/discord-message-schema.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./fixtures": {
      "types": "./dist/fixtures/index.d.ts",
      "import": "./dist/fixtures/index.js",
      "require": "./dist/fixtures/index.cjs"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=20"
  }
}
